# Discord Bot Configuration
# Your Discord bot token (from Developer Portal)
DISCORD_TOKEN=your-bot-token-here

# Discord channel ID where alerts are posted (e.g. from n8n webhook)
ALERTS_CHANNEL_ID=123456789

# Your Discord user ID (used for @mention on DEEP_ESCALATE alerts)
OWNER_USER_ID=987654321

# Claude API Configuration
# Anthropic API key for Claude Code (CLAUDE_CODE_OAUTH_TOKEN for newer Claude CLI)
CLAUDE_CODE_OAUTH_TOKEN=sk-...

# Kubernetes Configuration (Two separate kubeconfigs)
# Read-only kubeconfig for Claude (restricted to get/list/describe)
CLAUDE_RO_KUBECONFIG=/opt/claude-triager/kubeconfig-ro

# Read-write kubeconfig for the bot (for action execution and health checks)
BOT_RW_KUBECONFIG=/opt/claude-triager/kubeconfig-rw

# Policy System Prompt
# Path to Claude's system prompt file (instructions for triage behavior)
POLICY_SYSTEM_PROMPT=/opt/claude-triager/policy/system_prompt.txt

# Claude Model Selection (optional)
# Default is gpt-5.4-mini; set to override (e.g. gpt-5.5 for deeper analysis)
# CLAUDE_MODEL=gpt-5.5

# Heartbeat Configuration
# Interval in seconds to check cluster health via kubectl get --raw=/readyz
HEARTBEAT_INTERVAL=300

# Triager State and Logging
# Path to JSON file that persists rate-limit and recurrence state
TRIAGER_STATE_FILE=/opt/claude-triager/state/triager_state.json

# Path to log file (bot will create parent directories)
LOG_FILE=/var/log/triager.log

# Claude CLI Binary Path (default: 'claude' in PATH)
CLAUDE_BIN=claude
# Homeops git repo (read-only clone) - gives Claude the declared desired state + CLAUDE.md
HOMEOPS_REPO=/opt/claude-triager/homeops
